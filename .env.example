# Copy to .env and fill in real values. The .env file is gitignored and must
# never be committed. Only required if you use the database-graph tools, which
# connect to a Microsoft SQL Server instance.
DB_CONNECTION_STRING="DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-server;DATABASE=your-db;UID=your-user;PWD=your-password;Encrypt=yes;TrustServerCertificate=yes;"
